<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Calificar Receta -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_rounded_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="⭐  CALIFICAR RECETA"
                android:textColor="@color/primary_orange"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView android:id="@+id/star1" android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:tint="@color/star_gold" android:layout_marginEnd="4dp"/>
                <ImageView android:id="@+id/star2" android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:tint="@color/star_gold" android:layout_marginEnd="4dp"/>
                <ImageView android:id="@+id/star3" android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:tint="@color/star_gold" android:layout_marginEnd="4dp"/>
                <ImageView android:id="@+id/star4" android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:tint="@color/star_gold" android:layout_marginEnd="4dp"/>
                <ImageView android:id="@+id/star5" android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_outline" android:tint="@color/star_gold" android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_rating_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Muy bueno"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Unidades de Medida -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_rounded_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="⚖  UNIDADES DE MEDIDA"
                    android:textColor="@color/primary_orange"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gramos / °C"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_units"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Onzas / °F"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Dificultad -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🔥  DIFICULTAD"
                android:textColor="@color/primary_orange"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_facil"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_difficulty_normal"
                    android:gravity="center"
                    android:text="Fácil"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/btn_medio"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_difficulty_selected"
                    android:gravity="center"
                    android:text="Medio"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btn_dificil"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_difficulty_normal"
                    android:gravity="center"
                    android:text="Difícil"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Porciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🍽  PORCIONES"
                android:textColor="@color/primary_orange"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
                <SeekBar
                    android:id="@+id/seekbar_porciones"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:max="9"
                    android:progress="4"
                    android:progressTint="@color/primary_orange"
                    android:thumbTint="@color/primary_orange"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tv_porciones_value"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_orange"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_tiempo_estimado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tiempo estimado: 35 min"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/btn_calcular"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text="⚖  Calcular Ingredientes"
                android:textColor="@color/text_white"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Restricciones Alimentarias -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🚫  RESTRICCIONES ALIMENTARIAS"
                android:textColor="@color/primary_orange"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <CheckBox
                    android:id="@+id/cb_sin_gluten"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/primary_orange"
                    android:text="Sin gluten 🌾"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>

                <CheckBox
                    android:id="@+id/cb_vegano"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/primary_orange"
                    android:text="Vegano 🌿"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cb_sin_lactosa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/primary_orange"
                    android:text="Sin lactosa 🥛"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>

                <CheckBox
                    android:id="@+id/cb_sin_mariscos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/primary_orange"
                    android:text="Sin mariscos 🦐"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
