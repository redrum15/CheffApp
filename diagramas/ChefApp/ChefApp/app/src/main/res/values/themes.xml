<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ChefApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_brown</item>
        <item name="colorPrimaryDark">@color/primary_brown_dark</item>
        <item name="colorAccent">@color/primary_orange</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/primary_brown_dark</item>
        <item name="android:navigationBarColor">@color/primary_brown_dark</item>
    </style>

    <style name="TabSelected" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:textColor">@color/text_white</item>
        <item name="android:background">@color/primary_orange</item>
    </style>

    <style name="ObjectiveButton">
        <item name="android:padding">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ObjectiveButtonSelected">
        <item name="android:padding">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/primary_orange</item>
    </style>
</resources>
