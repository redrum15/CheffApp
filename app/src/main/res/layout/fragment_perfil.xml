<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@color/colorHeaderStart">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivFotoPerfil"
            android:layout_width="48dp"
            android:layout_height="48dp"/>

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="@color/colorWhite"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEditar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="✏️ Editar"
            android:textSize="11sp"
            android:backgroundTint="@null"
            android:textColor="@color/colorWhite"
            android:textStyle="bold"
            android:background="@drawable/bg_button_edit"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 INFORMACIÓN PERSONAL"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Edad" android:textColor="@color/colorGray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvEdad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Peso actual" android:textColor="@color/colorGray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvPeso" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Estatura" android:textColor="@color/colorGray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvEstatura" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="IMC" android:textColor="@color/colorGray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvImc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 OBJETIVO"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <Button
                            android:id="@+id/btnBajar"
                            android:layout_width="0dp"
                            android:layout_height="65dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:backgroundTint="#B43229"
                            android:text="Bajar ⬇️"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnMantener"
                            android:layout_width="0dp"
                            android:layout_height="65dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:backgroundTint="#B43229"
                            android:text="Mantener ⚖️"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnSubir"
                            android:layout_width="0dp"
                            android:layout_height="65dp"
                            android:layout_weight="1"
                            android:text="Subir ⬆️"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥗 PREFERENCIAS DIETÉTICAS"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPreferencias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAgregarPreferencia"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:layout_marginTop="8dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="+ Agregar"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:backgroundTint="@null"
                        android:textColor="@color/colorGray"
                        android:background="@drawable/bg_button_add" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- TÍTULO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ ALERGIAS E INTOLERANCIAS"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- BOTONES RÁPIDOS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">


                        <!-- BOTÓN AGREGAR -->

                    </LinearLayout>

                    <!-- CHIPS DINÁMICOS -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAgregarAlergia"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_button_add"
                        android:backgroundTint="@null"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="+ Agregar"
                        android:textColor="@color/colorGray"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupAlergias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- TÍTULO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️ ALIMENTOS FAVORITOS"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- FILA 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <Button
                            android:id="@+id/btnPasta"
                            android:layout_width="133dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:backgroundTint="#B43229"
                            android:text="Pasta 🍝"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnSushi"
                            android:layout_width="132dp"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#B43229"
                            android:text="Sushi 🍣"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- FILA 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <Button
                            android:id="@+id/btnTacos"
                            android:layout_width="131dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:backgroundTint="#B43229"
                            android:text="Tacos 🌮"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- CHIPS -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFavoritos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <!-- BOTÓN AGREGAR A LA DERECHA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAgregarFavorito"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_button_add"
                        android:backgroundTint="@null"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="+ Agregar"
                        android:textColor="@color/colorGray"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- TÍTULO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚫 ALIMENTOS QUE NO ME GUSTAN"
                        android:textColor="@color/colorOrange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- BOTONES RÁPIDOS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <Button
                            android:id="@+id/btnHigado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Hígado 🥩"
                            android:textSize="11sp"
                            android:textColor="@android:color/white"/>

                        <Button
                            android:id="@+id/btnRemolacha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remolacha 🍠"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- CHIPS -->

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAgregarNoGusta"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_button_add"
                        android:backgroundTint="@null"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="+ Agregar"
                        android:textColor="@color/colorGray"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupNoGustan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <!-- BOTÓN AGREGAR A LA DERECHA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
