<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:paddingTop="14dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:id="@+id/itemPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="84dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="10dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/iconPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="20sp"/>
        <TextView
            android:id="@+id/labelPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil"
            android:textStyle="bold"
            android:textSize="9sp"
            android:textColor="@color/colorLeftInactive"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemFotos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="62dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/iconFotos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍽️"
            android:textSize="19sp"/>
        <TextView
            android:id="@+id/labelFotos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotos"
            android:textStyle="bold"
            android:textSize="8.5sp"
            android:textColor="@color/colorLeftInactive"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="62dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/iconVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶️"
            android:textSize="19sp"/>
        <TextView
            android:id="@+id/labelVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Video"
            android:textStyle="bold"
            android:textSize="8.5sp"
            android:textColor="@color/colorLeftInactive"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemWeb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="62dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/iconWeb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="19sp"/>
        <TextView
            android:id="@+id/labelWeb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Web"
            android:textStyle="bold"
            android:textSize="8.5sp"
            android:textColor="@color/colorLeftInactive"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemBotones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:minHeight="62dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:id="@+id/iconBotones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎛️"
            android:textSize="19sp"/>
        <TextView
            android:id="@+id/labelBotones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Botones"
            android:textStyle="bold"
            android:textSize="8.5sp"
            android:textColor="@color/colorLeftInactive"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</LinearLayout>
