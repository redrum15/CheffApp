<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Contenido principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- AppBar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/colorDark"
            app:titleTextColor="@color/colorOrange"
            app:title="🍳 ChefApp"/>

        <!-- Fila principal: LeftFragment + Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Fragmento izquierdo fijo -->
            <FrameLayout
                android:id="@+id/frameLeft"
                android:layout_width="66dp"
                android:layout_height="match_parent"
                android:background="@color/colorLeftBg"/>

            <!-- Separador -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#2D1800"/>

            <!-- Fragmento derecho dinamico -->
            <FrameLayout
                android:id="@+id/frameRight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/colorBackground"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/colorDark"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/colorCream"
        app:itemIconTint="@color/colorOrange"/>

</androidx.drawerlayout.widget.DrawerLayout>